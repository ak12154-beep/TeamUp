# Database configuration
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<db_name>
DATABASE_URL_AMVERA=postgresql+psycopg://alt:root_123@amvera-altd09-cnpg-database-for-fip-rw:5432/DataBase_FIP?sslmode=disable

# JWT settings
JWT_SECRET=<strong_random_secret_min_32_chars>
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MIN=10080

# CORS configuration
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Application base URL (used for frontend links in AI service)
APP_BASE_URL=http://localhost:5173

# Local development fallback
LOCAL_DB_FALLBACK_ENABLED=false

# OpenAI configuration
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-5-nano

# SMTP configuration for email service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<smtp_user>
SMTP_PASSWORD=<smtp_password>
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Verification code settings
VERIFICATION_CODE_TTL_MIN=10
VERIFICATION_RESEND_SEC=60
VERIFICATION_CODE_LENGTH=6

# Post-game automation settings
POST_GAME_SCHEDULER_ENABLED=true
POST_GAME_POLL_SECONDS=60

# Required by backend startup admin sync
PRIMARY_ADMIN_EMAIL=admin@example.com
